###################################################################

#### Init #################

###################################################################

[ "${1}" = "-h" ] || [ "${1}" = "--help" ] || [ ${#} -lt 2 ] && help

########################### Mandatory

kdialog_bin=$(which kdialog)
[ -z "${kdialog_bin}" ] && echo "kdialog not found!" && exit 1

ffmpeg_bin=$(which ffmpeg)
[ -z "${ffmpeg_bin}" ] && \
	"${kdialog_bin}" --icon configure --title "${msg_common_software_not_found}" --error "${msg_common_ffmpeg_not_found}" && exit 2

########################### Optional

rife_bin=$(which rife-ncnn-vulkan)
[ ! -z "${rife_bin}" ] && rife_list="RIFE"

whisperx_bin=$($HOME/.local/share/pipx/venvs/whisperx)
[ ! -z "${whisperx_bin}" ] && whisperx_list="whisperx"

openai_whisper_bin=$($HOME/.local/share/pipx/venvs/openai-whisper)
[ ! -z "${openai_whisper_bin}" ] && openai_whisper_list="whisper"

srmd_bin=$(which srmd-ncnn-vulkan)
[ ! -z "${srmd_bin}" ] && srmd_list="SRMD $blk_srmd_list"; srmd_list_min="SRMD"

realsr_bin=$(which realsr-ncnn-vulkan)
[ ! -z "${realsr_bin}" ] && realsr_list="RealSR $blk_realsr_list"; realsr_list_min="RealSR"

realesrgan_bin=$(which /usr/share/realesrgan-ncnn-vulkan/realesrgan-ncnn-vulkan)
[ ! -z "${realesrgan_bin}" ] && realesrgan_list="Real-ESRGAN $blk_realesrgan_list"; realesrgan_list_min="Real-ESRGAN"

waifu2x_bin=$(which rife-ncnn-vulkan)
[ ! -z "${waifu2x_bin}" ] && waifu2x_list="Waifu2x"

action="${1}"
shift



load_strings
msg_title=msg_${action}_title
msg_finish_title=msg_${action}_finish_title

type set_${action} &> /dev/null || \
	{ "${kdialog_bin}" --icon configure --title "${msg_common_software_not_found}" --error "${msg_common_action_not_found_text}" && exit 3; }

ask_overwrite=false
set_${action} "${@}"

exit 0
