#### languages strings messages #################
# Syntax for strings name is: msg_[$format]_$window_[$section]
# For languages as sr@Latn use srLatn

###################################################################


## locale strings
#
#   Translators! If you wish to add a translation:
#    - Copy this chunk of code and paste it just below it.
#    - Change "en_US" to your language code. You can get it :
#        - From your system's language (copy : ' lang=${LANG//.?*/} && echo $lang ' in a terminal, then copy the result
#        - On this webpage : https://learn.microsoft.com/en-us/linkedin/shared/references/reference-tables/language-codes
#    - You're good to go :D  Please test your changes to see if it feels good and works okay.
#
#   Note : This script follows strictly your system language. If you want to force another one :
#    - On the line ' en_US && [ "${lang}" != "en_US" ] && ${lang} ' , remove everything but the first ' en_US ' and change it to your desired language
#    - You can look for it with Ctrl + F, search ' load_strings ' .
#
en_US () {
	### Common
	msg_common_software_not_found="Software not found"
	msg_common_ffmpeg_not_found="Software Ffmpeg not found! Please, install it."
	msg_common_rife_not_found="Software RIFE not found! Please, install it."
	msg_common_whisperx_not_found="Software whisperx not found! Please, install it."
	msg_common_openai_not_found="Software openai-whisper not found! Please, install it."
	msg_common_action_not_found="The requested action is not implemented."
	msg_common_overwrite="Do you want to keep the original files?"
	msg_common_abort="Operation interrupted by the user."
	msg_common_file_not_found="File \"${name}\" not found!"
	msg_common_name_error="The file name \"${name}\" does not match a recognized format for a date.${cr}${cr}The name must be of the type: YYYY-MM-DD_HHMMSS.jpg"
	msg_common_start="Initialising... "
	msg_common_progress="Processing file $processed of $quantity ($(basename "${input}"))"
	msg_common_finish_ok="Done."
	msg_common_finish_error="An error has occurred."
	msg_common_invalid_value="An invalid value was entered. Please, try again."


	### Actions

	### Compress
	msg_compress_title="Video compression with quality \"${value}\""
	msg_compress_quality_input_text="Type the quality:"
	msg_compress_finish_title="Compression of \"${name}\""

	### Rotate
	msg_rotate_title="Rotate file with angle of \"${value}\""
	msg_rotate_angle_input_text="Enter the desired rotation angle:"
	msg_rotate_finish_title="Rotation \"${name}\""

	### Resize
	msg_resize_title="Resize file with \"${profile}\" method:"
	msg_resize_profile_input_text="Choose which resizing method should be used (\"${def_profile}\" by default):${cr}"
	msg_resize_finish_title="Resizing \"${name}\""

    ### Interpolate
	msg_interpolate_title="Interpolating with \"${model}\" by ${multiplicator}"
	msg_interpolate_multiplicator_input_text="Choose the number by which you want to${cr}multiply the video(s)'s frame count (2 by default):"
	msg_gpu_interpolate_input_text="${blk_gpu_available}Choose a model for interpolation ($def_model by default).${cr}${cr}'Minterpolate' runs exclusively on CPU, which is slow!${cr}"
	msg_interpolate_finish_title="Interpolation of \"${name}\" by ${multiplicator}"

    ### Restore
	msg_restore_title="Restoring by doing \"${subaction}\" with \"${title_model}\""
	msg_subaction_input_text="${blk_gpu_available}What do you want to do? ('${def_subaction}' by default)"
	msg_restore_gpu_input_text="Choose a model for restoring ('${def_model}' by default).${cr}'SRMD', 'RealSR' and 'Real-ESRGAN' benefits from your GPU but may be more inconsistent depending of the model."
	msg_restore_denoise_input_text="Enter a value for denoise intensity, $min_denoise to $max_denoise${cr}($def_denoise by default).${cr}Lower equals lower quality but longer process time.${cr}${cr}Tuning it may be necessary depending of the noise quantity.${cr}"
	msg_restore_upscale_input_text="Choose the number by which you want to${cr}upscale the video(s)'s resolution ('${def_multi}' by default):"
	msg_restore_finish_title="Restauration of \"${name}\" with \"${model}\""

    ### Reencode
	msg_reencode_h264_title="Reencoding to h264"
	msg_reencode_h264_finish_title="Reencode \"${name}\" to h264"

	msg_reencode_hevc_title="Reencoding to HEVC"
	msg_reencode_hevc_finish_title="Reencode \"${name}\" to HEVC"

	msg_reencode_vp9_title="Reencoding to VP9"
	msg_reencode_vp9_finish_title="Reencode \"${name}\" to VP9"

	msg_reencode_prores_title="Reencoding to ProRes"
	msg_reencode_prores_finish_title="Reencode \"${name}\" to ProRes"

	msg_reencode_dnxhd_title="Reencoding to DNxHD"
	msg_reencode_dnxhd_finish_title="Reencode \"${name}\" to DNxHD"

	msg_dnxhd_profile_encode_input_text="Choose a profile, depending of the media(s)'s characteristics ('$def_profile' by default).${cr}"
	msg_prores_profile_encode_input_text="Choose a profile, depending of the media(s)'s characteristics ('$def_profile' by default).${cr}${cr}When in doubt, choose 'Auto'.${cr}"
	msg_bitrate_encode_input_text="Enter a value for bitrate limit, $min_bitrate to $max_bitrate ($def_bitrate by default).${cr}Lower equals better quality but bigger file.${cr}${cr}Tuning it may be necessary for videos with a lot of movement.${cr}"
	msg_quality_encode_input_text="Choose a speed for compression ('${def_quality}' by default).${cr}Slower equals better quality but slower encoding / decoding time.${cr}"
	msg_gpu_encode_input_text="${blk_gpu_available}Choose an encoding method ($def_encoder by default).${cr}${cr}GPU encoding may be faster depending of it's performance.${cr}It will also free your computer for other tasks.${cr}"
	msg_multithread_input_text="Do you want to run in multithread ?${cr}${cr}This will completly mobilise your CPU, accelerating${cr}the encoding speed at the cost of your computer's reactivity.${cr}${cr}Recommended if you're not going to use it during operation.${cr}"

	msg_pcm_profile_encode_input_text="Choose a profile, depending of the media(s)'s characteristics ('$def_profile' by default).${cr}"

	msg_codec_encode_input_text="Enter the desired codec:"
	msg_profile_encode_input_text="Enter the desired profile:"



	msg_afallback_encode_input_text="'${base}.${ext}''s audio codec is not known from revideo.${cr}It will fallback to either a lossless codec (PCM) or a lossy one (Opus)${cr}($def_afallback by default)${cr}${cr}Choose one:${cr}"
	msg_vfallback_encode_input_text="'${base}.${ext}''s video codec is not known from revideo.${cr}It will fallback to either a lossless codec (ProRes) or a lossy one (h264)${cr}($def_vfallback by default)${cr}${cr}Choose one:${cr}"


	### Building blocks
	blk_srmd_list="(Best for Real-Life)"
	blk_realsr_list="(Best for Real-Life)"
	blk_realesrgan_list="(Best for Animation)"
    blk_gpu_available="One or multiple compatible GPU(s) were detected.${cr}"


	### Lists
	list_restore_denoise="Denoise"; list_restore_upscale="Upscale" list_restore_all="Combine the two's"
	list_nlmeans="Nlmeans (Slower, more precise)" list_atadenoiser="Atadenoiser (Faster, less precise)"

	list_pcm_s16be="PCM 16 Bits"; list_pcm_s24be="PCM 24 Bits"; list_pcm_f32be="PCM Floating 32 Bits"

	list_lossless="Lossless"; list_lossy="Lossy"
	list_resize_stretch="Stretch" list_resize_fill="Fill" list_resize_bars="Black Bars"


    ### File Attachments
    file_horizontal_cut="_frames"; file_vertical_cut="_stripped"; file_vertical_cut_v="_video"; file_vertical_cut_a="_audio"
    lock_en_US () {
		file_converted="_converted"; file_rotated="_rotated"; file_resized="_resized"
		file_interpolated="_interpolated"; file_denoised="_denoised"; file_upscaled="_denoised"; file_restore_all="_upscaled and denoised"
		file_sepia="_sepia"; file_gray="_gray"
		file_deinterlaced="_deinterlaced"
    }
}


load_strings () {
    cr="
    "
	## Load localized strings AFTER english strings
	## - if localized strings not found use english for default
	## - if localized strings are incomplete use english only fot missing strings :-)
	## - lock_en_US separated and managed by overwrite
	en_US && [ "${lang}" != "en_US" ] && ${lang}
	[ "${overwrite}" = false ] && lock_en_US && [ "${lang}" != "en_US" ] && file_${lang}
}

lang=${LANG//.?*/}
type ${lang} &> /dev/null || lang='en_US'
load_strings

