	echo "TODO"
	echo
	exit 0
}










###################################################################

#### Run functions #################

# Notes :
# Write conditions as 'if elsefi else fi' to avoid returning 1 by accident
# Sleep delays may be necessary to avoid the script locking up when processing multiple files

###################################################################


######################################## Run Convert pro

run_reencode_dnxhd () {

    sleep 0.8

	if [ "${overwrite}" = true ]; then cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}"; fi

	if [ "${overwrite}" = true ]; then
		< /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "/tmp/${base}_TEMP.mov" -c:v "${vcodec}" -profile:v "${vprofile}" -pix_fmt "${vpixfmt}" -c:a copy "${dir}/${base}.mov" 2>&1 );
	else
		msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -c:v "${vcodec}" -profile:v "${vprofile}" -pix_fmt "${vpixfmt}" -c:a copy "${dir}/${base}${file_converted}.mov" 2>&1);
	fi

	if [ "${overwrite}" = true ]; then rm -f "/tmp/${base}_TEMP.mov"; fi

	return $?
}

run_reencode_prores () {

    sleep 0.8

	if [ "${overwrite}" = true ]; then cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}"; fi

	if [ "${overwrite}" = true ]; then
		< /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "/tmp/${base}_TEMP.mov" -c:v "${vcodec}"$opt_profile -c:a copy "${input}" 2>&1 );
	else
		msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -c:v "${vcodec}"${opt_profile} -c:a copy "${dir}/${base}${file_converted}.mov" 2>&1);
	fi

	if [ "${overwrite}" = true ]; then rm -f "/tmp/${base}_TEMP.mov"; fi

	return $?
}

######################################## Run Convert

run_reencode_h264 () {

	sleep 0.8

	if [ "${overwrite}" = true ]; then cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}"; fi

	if [ "${overwrite}" = true ];  then
		< /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "/tmp/${base}_TEMP.${ext}" -pix_fmt yuv420p -c:v "${vcodec}" -c:a copy${opt_bitrate} -preset "${vquality}" "${input}" 2>&1);
	else
		msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -pix_fmt yuv420p -c:v "${vcodec}" -c:a copy${opt_bitrate} -preset "${vquality}" "${dir}/${base}${file_converted}.${ext}" 2>&1);
	fi

	if [ "${overwrite}" = true ]; then rm -f "/tmp/${base}_TEMP.${ext}"; fi

	return $?
}

run_reencode_hevc () {

    sleep 0.8

	if [ "${overwrite}" = true ]; then cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}"; fi

	if [ "${overwrite}" = true ];  then
		< /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "/tmp/${base}_TEMP.${ext}" -pix_fmt yuv420p -c:v "${vcodec}" -c:a copy${opt_bitrate} -preset "${vquality}" "${input}" 2>&1);
	else
		msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -pix_fmt yuv420p -c:v "${vcodec}" -c:a copy${opt_bitrate} -preset "${vquality}" "${dir}/${base}${file_converted}.${ext}" 2>&1);
	fi

	if [ "${overwrite}" = true ]; then rm -f "/tmp/${base}_TEMP.${ext}"; fi

	return $?
}

run_reencode_vp9 () {

	if [ "${vcodec}" = "libvpx-vp9" ];  then

		sleep 0.8

		[ "${overwrite}" = true ] && cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}"

		if [ "${overwrite}" = true ];  then
		    < /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -pass 1 -b:v 0 -pix_fmt yuv420p10le -c:v "${vcodec}" -c:a copy${opt_bitrate} -quality "${vquality}" -row-mt "${multithread}" -f null /dev/null && \ 2>&1);
		else
		    < /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -pass 2 -b:v 0 -pix_fmt yuv420p10le -c:v "${vcodec}" -c:a copy${opt_bitrate} -quality "${vquality}" -row-mt "${multithread}" "${input}" 2>&1);
		fi

		[ "${overwrite}" = true ] && rm "/tmp/${base}_TEMP.${ext}"

	elif [ "${vcodec}" = "vp9_qsv" ];  then

		sleep 0.8

		[ "${overwrite}" = true ] && cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}"

        if [ "${overwrite}" = true ];  then
            < /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "${input}" "/tmp/${base}_TEMP.webm" -c:v "${vcodec}" -preset "${vquality}" -c:a libopus "${input}" 2>&1);
        else
            msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -c:v "${vcodec}" -preset "${vquality}" -c:a libopus "${dir}/${base}${file_converted}.webm" 2>&1);
        fi

		[ "${overwrite}" = true ] && rm "/tmp/${base}_TEMP.${ext}"

	fi

	return $?
}

run_reencode_audio () {

	if [ "${overwrite}" = true ];  then
		sleep 0.8

		[ "${overwrite}" = true ] && cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}"

		if [ "${overwrite}" = true ];  then
		< /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "/tmp/${base}_TEMP.${ext}" -c:v copy -c:a "${acodec}" "${input}" 2>&1);
		else
		msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -c:v copy -c:a "${acodec}" "${dir}/${base}${file_converted}.${ext}" 2>&1);
		fi

		[ "${overwrite}" = true ] && rm "/tmp/${base}_TEMP.${ext}"
	fi

	return $?
}

######################################## Run Resize

run_resize () {

	width=$(ffprobe -v error -select_streams v:0 -show_entries stream=width -of csv=p=0:s=x "${dir}/${base}.${ext}" 2>&1)
	value=$(echo "${value}" | sed "s~OG_W~$width~g" 2>&1)

	height=$(ffprobe -v error -select_streams v:0 -show_entries stream=height -of csv=p=0:s=x "${dir}/${base}.${ext}" 2>&1)
	value=$(echo "${value}" | sed "s~OG_H~$height~g" 2>&1)

    sleep 0.8

	if [ "${profile}" = "${list_resize_stretch}" ]; then
		opt_resize=",setsar=1"
	elif [ "${profile}" = "${list_resize_fill}" ]; then
		opt_resize=":force_original_aspect_ratio=increase,crop=$value"    		      # Workaround for filters changing the iw / ih values.
	elif [ "${profile}" = "${list_resize_bars}" ]; then								  # Maybe filter complex would be possible but don't want to bother for now (TODO)
		opt_resize=":force_original_aspect_ratio=decrease,pad=$value:-1:-1:color=black"
	fi

    [ "${overwrite}" = true ] && cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}"


	if [ "${overwrite}" = true ];  then
		< /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "/tmp/${base}_TEMP.${ext}" -vf "scale=$value$opt_resize" "${input}" 2>&1);
	else
		msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -vf "scale=$value$opt_resize" "${dir}/${base}${file_resized}.${ext}" 2>&1);
	fi

	[ "${overwrite}" = true ] && rm "/tmp/${base}_TEMP.${ext}"

	return $?

}

######################################## Run Rewrap

run_rewrap () {

    sleep 0.8

	if [ "${overwrite}" = true ] && [ "${ext}" = "${format}" ]; then
		msg=$("${ffmpeg_bin}" -i "${input}" -c copy -map 0 "${input}.${format}" 2>&1)
	else
		msg=$("${ffmpeg_bin}" -i "${input}" -c copy -map 0 "${dir}/${base}.${format}" 2>&1)
	fi

	return $?

}

######################################## Run Tools

run_horizontal_disassemble () {

    sleep 0.8

	mkdir "${dir}/${base}${file_horizontal_cut}"
	msg=$("${ffmpeg_bin}" -i "${input}" "${dir}/${base}${file_horizontal_cut}/${base}_%03d.${value}" 2>&1)

    if [ "${overwrite}" = true ]; then rm "${input}"; fi

	return $?
}

run_vertical_disassemble () {

    sleep 0.8

    detect_vcodec=$(ffprobe -i "${dir}/${base}.${ext}" 2>&1 | grep -i Video: ); [[ ${detect_vcodec} = *"Video:"* ]] && detect_video_codec
	detect_acodec=$(ffprobe -i "${dir}/${base}.${ext}" 2>&1 | grep -i Audio: ); [[ ${detect_acodec} = *"Audio:"* ]] && detect_audio_codec

    mkdir "${dir}/${base}${file_vertical_cut}"

	if [ ! -z "${detect_vcodec}" ]; then msg=$("${ffmpeg_bin}" -i "${input}" -map 0:v "${dir}/${base}${file_vertical_cut}/${base}${file_vertical_cut_v}.${vext}" 2>&1); fi
	if [ ! -z "${detect_acodec}" ]; then msg=$("${ffmpeg_bin}" -i "${input}" -map 0:a "${dir}/${base}${file_vertical_cut}/${base}${file_vertical_cut_a}.${aext}" 2>&1); fi

	if [ "${overwrite}" = true ]; then rm "${input}"; fi

	return $?
}

run_interpolate () {

	base="${base}"

	if [ "${value}" = "minterpolate" ]; then

		vfps=$(ffmpeg -i "${dir}/${base}.${ext}" 2>&1 | sed -n 's/.*, \(.*\) fp.*/\1/p')
		vfps_multiplied=$((${vfps} * ${multiplicator}))

		[ "${overwrite}" = true ] && cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}" && rm "/tmp/${base}_TEMP.${ext}"

		if [ "${overwrite}" = true ]; then
		< /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "/tmp/${base}_TEMP.${ext}" -filter:v minterpolate -r "${vfps_multiplied}" "${input}" 2>&1 );
		else
		< /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -filter:v minterpolate -r "${vfps_multiplied}" "${dir}/${base}${file_interpolated}.${ext}" 2>&1 );
		fi

		vfps=$(ffmpeg -i "${dir}/${base}.${ext}" 2>&1 | sed -n 's/.*, \(.*\) fp.*/\1/p')
		vfps_multiplied=$((${vfps} * ${multiplicator}))

	else

		common_ncnn_start

		"${value}" -m "/usr/share/rife-ncnn-vulkan/rife-v4.25-heavy" -n $[ ${vfps_total} * ${multiplicator} ] -i "/tmp/${base}_input_TEMP" -o "/tmp/${base}_output_TEMP"

		common_ncnn_end

	fi
	return $?
}

run_restore () {

	base="${base}"

	if [ "${value}" = "nlmeans" ] || [ "${value}" = "atadenoiser" ]; then

		vfps=$(ffmpeg -i "${dir}/${base}.${ext}" 2>&1 | sed -n 's/.*, \(.*\) fp.*/\1/p')
		vfps_total=$(ffprobe -v error -select_streams v:0 -count_packets -show_entries stream=nb_read_packets -of csv=p=0 "${dir}/${base}.${ext}")
		vfps_multiplied=$((${vfps} * ${multiplicator}))

		if [ "${overwrite}" = true ]; then cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}" && rm "/tmp/${base}_TEMP.${ext}"; fi

		if [ "${overwrite}" = true ]; then
		< /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "/tmp/${base}_TEMP.${ext}" -filter:v minterpolate -r "${vfps_multiplied}" "${input}" 2>&1 );
		else
		< /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -filter:v minterpolate -r "${vfps_multiplied}" "${dir}/${base}${file_interpolated}.${ext}" 2>&1 );
		fi

	else

		common_ncnn_start

		"${value}" -s ${multiplicator} -i "/tmp/${base}_input_TEMP" -o "/tmp/${base}_output_TEMP$opt_restore"

		common_ncnn_end

	fi
	return $?
}

run_add_music () {

    sleep 0.8

    # msg=$("${ffmpeg_bin}" -i "${input}" -i "${add_input}" -filter_complex filter_complex \
    # "[0:v]trim=start=0[out0];[0:a]atrim=start=0[out1];[out1][1:a]sidechaingate=level_in=1:mode=downward:threshold=0.125:ratio=2:attack=20:release=250:makeup=1:knee=2.828427125:detection=rms[out2]" \
    # -map "[out0]" -map "[out2]" "${dir}/${base}_music_added.${ext}" 2>&1 )

    # msg=$("${ffmpeg_bin}" -i "${input}" -i "${add_input}" -filter_complex \
    # "[0:v]trim=start=0[out0];[0:a]atrim=start=0[out1];[out1][1:a]amix=inputs=2:duration=longest:dropout_transition=2:weights=1 1:normalize=1[out2]" \
    # -map "[out0]" -map "[out2]" "${dir}/${base}_music_added.${ext}" 2>&1 )

    msg=$("${ffmpeg_bin}" -i "${input}" -i "${add_input}" \
    -map 0:v -map 1:a "${dir}/${base}_music_added.${ext}" 2>&1 )

    if [ "${overwrite}" = true ]; then rm "${input}"; fi

    return $?
}

run_sepia () {

    [ "${overwrite}" = true ] && cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}"

	if [ "${overwrite}" = true ];  then
		msg=$("${ffmpeg_bin}" -i "${dir}/${base}_TEMP.${ext}" -filter_complex colorchannelmixer=.393:.769:.189:0:.349:.686:.168:0:.272:.534:.131 -c:a copy "${input}" 2>&1)
	else
		msg=$("${ffmpeg_bin}" -i "${input}" -filter_complex colorchannelmixer=.393:.769:.189:0:.349:.686:.168:0:.272:.534:.131 -c:a copy "${dir}/${base}${file_sepia}.${ext}" 2>&1)
	fi

	[ "${overwrite}" = true ] && rm "${dir}/${base}_TEMP.${ext}"

	return $?
}

run_gray () {

    [ "${overwrite}" = true ] && cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}"

	if [ "${overwrite}" = true ];  then
		msg=$("${ffmpeg_bin}" -i "${dir}/${base}_TEMP.${ext}" -filter_complex colorchannelmixer=.393:.769:.189:0:.349:.686:.168:0:.272:.534:.131 -c:a copy "${input}" 2>&1)
	else
		msg=$("${ffmpeg_bin}" -i "${input}" -vf extractplanes=y -c:a copy "${dir}/${base}${file_gray}.${ext}" 2>&1)
	fi

	[ "${overwrite}" = true ] && rm "${dir}/${base}_TEMP.${ext}"

	return $?
}

######################################## Run Rotate

run_overturn () {

    [ "${overwrite}" = true ] && cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}"

	if [ "${overwrite}" = true ];  then
		msg=$("${ffmpeg_bin}" -i "${dir}/${base}_TEMP.${ext}" -filter:v "${value}" -c:a copy "${input}" 2>&1)
	else
		msg=$("${ffmpeg_bin}" -i "${input}" -filter:v "${value}" -c:a copy "${dir}/${base}${file_rotated}.${ext}" 2>&1)
	fi

	[ "${overwrite}" = true ] && rm "${dir}/${base}_TEMP.${ext}"

	return $?
}

run_rotate () {

    [ "${overwrite}" = true ] && cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}"

	if [ "${overwrite}" = true ];  then
		msg=$("${ffmpeg_bin}" -display_rotation "${angle}" -i "${dir}/${base}_TEMP.${ext}" -c:a copy "${input}" 2>&1)
	else
		msg=$("${ffmpeg_bin}" -display_rotation "${angle}" -i "${input}" -c:a copy "${dir}/${base}${file_rotated}.${ext}" 2>&1)
	fi

	[ "${overwrite}" = true ] && rm "${dir}/${base}_TEMP.${ext}"

	return $?
}











###################################################################

#### Video Audio Codec / Hardware / GPU detect #################

###################################################################

detect_gpu_h264_hevc () {
	gpu_choice=$(lspci | grep -i '.* vga .*')

	if [[ "{$gpu_choice}" == *'UHD Graphics'* ]]; then
		gpu_list="${gpu_list}Intel "
		def_encoder="Intel"
	fi
	if [[ "{$gpu_choice}" == *'GeForce'* ]]; then
		gpu_list="${gpu_list}Nvidia "
		def_encoder="Nvidia"
	fi
	gpu_list="${gpu_list}CPU"
}

detect_gpu_interpolate () {
	gpu_choice=$(lspci | grep -i '.* vga .*')

	if [[ "{$gpu_choice}" == *'GeForce'* ]]; then
		gpu_list="${gpu_list}Nvidia "
		def_encoder="Nvidia"
	fi
	if [[ "{$gpu_choice}" == *'Radeon'* ]]; then
		gpu_list="${gpu_list}AMD "
		def_encoder="AMD"
	fi
	gpu_list="${gpu_list}CPU"
}

detect_gpu_restore () {
	gpu_choice=$(lspci | grep -i '.* vga .*')

	if [[ "{$gpu_choice}" == *'GeForce'* ]]; then
		gpu_list="${gpu_list}Nvidia "
		def_encoder="Nvidia"
	fi
	if [[ "{$gpu_choice}" == *'Radeon'* ]]; then
		gpu_list="${gpu_list}AMD "
		def_encoder="AMD"
	fi
	gpu_list="${gpu_list}CPU"
}

detect_gpu_vp9 () {
	gpu_choice=$(lspci | grep -i '.* vga .*')

	if [[ "{$gpu_choice}" == *'UHD Graphics'* ]]; then
		gpu_list="${gpu_list}Intel "
		def_encoder="Intel"
	fi
	gpu_list="${gpu_list}CPU"
}

detect_video_codec () {

	def_vfallback=$list_lossless

	vfallback_list=("$list_lossless $list_lossy")

	## Prores
	if [[ ${detect_vcodec} = *"prores"* ]]; then
	vcodec="prores"; vext="mov"; acodec="copy"; vpixfmt="yuv422p10"
	opt_audio=" -c:a $acodec"; opt_video=" -c:v $vcodec"
		if [[ ${detect_vcodec} = *"(Proxy)"* ]]; then
		vprofile="0"; acodec="copy"
		opt_video=" -c:v $vcodec -profile:v $vprofile -pix_fmt $vpixfmt"
		elif [[ ${detect_vcodec} = *"(LT)"* ]]; then
		vprofile="1"; acodec="copy"
		opt_video=" -c:v $vcodec -profile:v $vprofile -pix_fmt $vpixfmt"
		elif [[ ${detect_vcodec} = *"(Standard)"* ]]; then
		vprofile="2"; acodec="copy"
		opt_video=" -c:v $vcodec -profile:v $vprofile -pix_fmt $vpixfmt"
		elif [[ ${detect_vcodec} = *"(HQ)"* ]]; then
		vprofile="3"; acodec="copy"
		opt_video=" -c:v $vcodec -profile:v $vprofile -pix_fmt $vpixfmt"
		elif [[ ${detect_vcodec} = *"(4444)"* ]]; then
		vprofile="4"; acodec="copy"
		opt_video=" -c:v $vcodec -profile:v $vprofile -pix_fmt $vpixfmt"
		elif [[ ${detect_vcodec} = *"(XQ)"* ]]; then
		vprofile="5"; acodec="copy"
		opt_video=" -c:v $vcodec -profile:v $vprofile -pix_fmt $vpixfmt"
		fi

	## DNXHD
	elif [[ ${detect_vcodec} = *"dnxhd"* ]]; then
	vcodec="dnxhd"; vext="mov"; acodec="copy"
	opt_audio=" -c:a $acodec"
		if [[ ${detect_vcodec} = *"(DNXHR LB)"* ]]; then
		vprofile="dnxhr_lb"; vpixfmt="yuv422p"
		opt_video=" -c:v $vcodec -profile $vprofile -pix_fmt $vpixfmt"
		elif [[ ${detect_vcodec} = *"(DNXHR SQ)"* ]]; then
		vprofile="dnxhr_sq"; vpixfmt="yuv422p"
		opt_video=" -c:v $vcodec -profile $vprofile -pix_fmt $vpixfmt"
		elif [[ ${detect_vcodec} = *"(DNXHR HQ)"* ]]; then
		vprofile="dnxhr_hq"; vpixfmt="yuv422p"
		opt_video=" -c:v $vcodec -profile $vprofile -pix_fmt $vpixfmt"
		elif [[ ${detect_vcodec} = *"(DNXHR HQX)"* ]]; then
		vprofile="dnxhr_hqx"; vpixfmt="yuv422p10le"
		opt_video=" -c:v $vcodec -profile $vprofile -pix_fmt $vpixfmt"
		elif [[ ${detect_vcodec} = *"(DNXHR 444)"* ]]; then
		vprofile="dnxhr_444"; vpixfmt="yuv422p10le"
		opt_video=" -c:v $vcodec -profile $vprofile -pix_fmt $vpixfmt"
		fi

	## H264
	elif [[ ${detect_vcodec} = *"h264"* ]]; then
	vcodec="libx264";  vext="${ext}"; vbitrate=20; vquality=medium
	opt_video=" -c:v $vcodec -crf $vbitrate -preset $vquality -pix_fmt yuv420p"

		#if [[ ${detect_vcodec} = *"h264"* ]] && [ def_encoder="Nvidia" ]; then
		#vcodec="h264_nvenc"; vquality=p3											NVENC seems to be bad with image re-assembling (very blocky)
		#opt_video=" -c:v $vcodec -preset $vquality"

		#elif [[ ${detect_vcodec} = *"h264"* ]] && [ def_encoder="Intel" ]; then
		#vcodec="h264_qsv"; vquality=slow
		#opt_video=" -c:v $vcodec -preset $vquality"								Not sure for Intel (QSV won't work on mine)
		#fi

	## NVENC
	elif [[ ${detect_vcodec} = *"nvenc"* ]]; then
	vcodec="libx265"; vext="${ext}" vbitrate=23; vquality=medium
	opt_video=" -c:v $vcodec -crf $vbitrate -preset $vquality"

		#if [[ ${detect_vcodec} = *"nvenc"* ]] && [ def_encoder="Nvidia" ]; then
		#vcodec="hevc_nvenc"; vquality=p4
		#opt_video=" -c:v $vcodec -preset $vquality"
		#fi

	## VP9
	elif [[ ${detect_vcodec} = *"vp9"* ]]; then
	vcodec="libvpx-vp9"; vext="${ext}" vbitrate=27; vquality=good
	opt_video=" -c:v $vcodec -crf $vbitrate -preset $vquality"

		#if [[ ${detect_vcodec} = *"vp9"* ]] && [ def_encoder="Intel" ]; then
		#vcodec="vp9_qsv"; vquality=medium
		#opt_video=" -c:v $vcodec -preset $vquality"
		#fi

	else
		load_strings

		vcodec=""; vprofile=""; vquality=""; vbitrate=""

		vfallback=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_vfallback_encode_input_text}" $vfallback_list) || \
			{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
		if [ "${fallback}" = "" ]; then fallback="${def_vfallback}"
		fi

		if [ $vfallback=$list_lossless ]; then
			if [ "${overwrite}"=true ]; then
				sleep 0.8
				cp "${input}" "/tmp/${base}_TEMP.${ext}"
				rm "${input}"


				< /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "/tmp/${base}_TEMP.${ext}" -c:v prores -c:a copy "${input}" 2>&1)
				rm "/tmp/${base}_TEMP.${ext}"

			else
				msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -c:v prores -c:a copy "${dir}/${base}${file_converted}.${ext}" 2>&1)
				base="${base}${file_converted}"
			fi
		elif [ $vfallback=$list_lossy ]; then

			if [ $def_encoder="Nvidia" ]; then
				vcodec="h264_nvenc"; vquality=p4
				opt_video=" -c:v $vcodec -crf $vbitrate -preset $vquality"
			elif [ $def_encoder="Intel" ]; then
				vcodec="h264_qsv"; vquality=slow
			else
				vcodec="libx264"; vbitrate=20; vquality=medium
				opt_video=" -c:v $vcodec -crf $vbitrate -preset $vquality"
			fi
			if [ "${overwrite}"=true ]; then
				sleep 0.8
				cp "${input}" "/tmp/${base}_TEMP.${ext}"
				rm "${input}"

				< /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "/tmp/${base}_TEMP.${ext}" -c:v "${vcodec}" -c:a copy "${input}" 2>&1)
				rm "/tmp/${base}_TEMP.${ext}"
			else
				msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -c:v "${vcodec}" -c:a copy "${dir}/${base}${file_converted}.${ext}" 2>&1)
				base="${base}${file_converted}"

			fi
		fi

	fi
}

detect_audio_codec () {

	def_afallback=${list_lossless}

	afallback_list=("$list_lossless $list_lossy")

	## PCM
	if [[ ${detect_acodec} = *"pcm"* ]]; then
	profile=ffprobe -i "${dir}/${base}.${ext}" 2>&1 | grep -o -P '(?<=pcm_).*?(?= \()'
	acodec="pcm_$profile"; aext="waw"

	## AAC
	elif [[ ${detect_acodec} = *"aac"* ]]; then
	acodec="aac"; aext="m4a"

	## Vorbis
	elif [[ ${detect_acodec} = *"vorbis"* ]]; then
	acodec="libvorbis"; aext="ogg"

	## Opus
	elif [[ ${detect_acodec} = *"opus"* ]]; then
	acodec="opus"; aext="ogg"

	## Alac
	elif [[ ${detect_acodec} = *"alac"* ]]; then
	acodec="alac"; aext="waw"

	## Flac
	elif [[ ${detect_acodec} = *"flac"* ]]; then
	acodec="flac"; aext="flac"

	else
		load_strings

		acodec=""; aext=""

		afallback=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_afallback_encode_input_text}" $afallback_list) || \
			{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
		if [ "${afallback}" = "" ]; then afallback="${def_afallback}"
		fi

		if [ "${afallback}" = "${list_lossless}" ]; then
			acodec="pcm"; aext="waw"
			if [ "${overwrite}" = true ]; then
				sleep 0.8
				cp "${input}" "/tmp/${base}_TEMP.${ext}"
				rm "${input}"


				< /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "/tmp/${base}_TEMP.${ext}" -c:v copy -c:a pcm_s16le "${input}" 2>&1)
				rm "/tmp/${base}_TEMP.${ext}"

			else
				msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -c:v copy -c:a pcm_s16le "${dir}/${base}${file_converted}.${ext}" 2>&1)
				base="${base}${file_converted}"
			fi
		elif [ "${afallback}" = "${list_lossy}" ]; then
			acodec="opus"; aext="ogg"
			if [ "${overwrite}" = true ]; then
				sleep 2
				cp "${input}" "/tmp/${base}_TEMP.${ext}"
				rm "${input}"


				< /dev/null msg=$("${ffmpeg_bin}" -nostdin -i "/tmp/${base}_TEMP.${ext}" -c:v copy -c:a libopus "${input}" 2>&1)
				rm "/tmp/${base}_TEMP.${ext}"
			else
				sleep 2
				msg=$("${ffmpeg_bin}" -nostdin -i "${input}" -c:v copy -c:a libopus "${dir}/${base}${file_converted}.${ext}" 2>&1)
				base="${name%.*}${file_converted}"
			fi
		fi

	fi
}




















###################################################################

#### Common functions that are reused #################

###################################################################

common_ncnn_start () {

    # Setup
 	vfps=$(ffmpeg -i "${dir}/${base}.${ext}" 2>&1 | sed -n 's/.*, \(.*\) fp.*/\1/p')
	vfps_total=$(ffprobe -v error -select_streams v:0 -count_packets -show_entries stream=nb_read_packets -of csv=p=0 "${dir}/${base}.${ext}")
	vfps_multiplied=$((${vfps} * ${multiplicator}))

	detect_vcodec=$(ffprobe -i "${dir}/${base}.${ext}" 2>&1 | grep -i Video: ); [[ ${detect_vcodec} = *"Video:"* ]] && detect_video_codec
	detect_acodec=$(ffprobe -i "${dir}/${base}.${ext}" 2>&1 | grep -i Audio: ); [[ ${detect_acodec} = *"Audio:"* ]] && detect_audio_codec

	# Disassemble
	mkdir "/tmp/${base}_input_TEMP"
	mkdir "/tmp/${base}_output_TEMP"
	ffmpeg -i "${dir}/${base}.${ext}" -vn -acodec copy "/tmp/${base}audio_TEMP.${aext}"
	ffmpeg -i "${dir}/${base}.${ext}" "/tmp/${base}_input_TEMP/frame_%08d.png"

	if [ "${overwrite}" = true ]; then cp "${input}" "/tmp/${base}_TEMP.${ext}" && rm "${input}"; fi
}

common_ncnn_end () {

    # Reassemble
    if [ "$detect_acodec" != "" ]; then
		msg=$("${ffmpeg_bin}" -framerate "${vfps_multiplied}" -i "/tmp/${base}_output_TEMP/%08d.png" -i "/tmp/${base}audio_%08d.${aext}"$opt_video$opt_audio "${dir}/${base}${file_interpolated}.${vext}" 2>&1 )
	else
		msg=$("${ffmpeg_bin}" -framerate "${vfps_multiplied}" -i "/tmp/${base}_output_TEMP/%08d.png" $opt_video "${dir}/${base}${file_interpolated}.${vext}" 2>&1 )
	fi

	# Wipe
	rm -r "/tmp/${base}_input_TEMP"
	rm -r "/tmp/${base}_output_TEMP"
	if [ "${overwrite}" = true ]; then rm "/tmp/${base}_TEMP.${ext}"; fi
	if [ "${detect_acodec}" != "" ]; then rm -f "/tmp/${base}audio_TEMP.${aext}"; fi
}






###################################################################

#### Input managers #################

###################################################################

overwrite_prompt () {
	"${kdialog_bin}" --icon configure --title "${!msg_title}" --warningyesno "${msg_common_overwrite}" && overwrite=false || \
		{
			[ $? -eq 1 ] && overwrite=true || \
				{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
		}
	if [ "${overwrite}" = true ];  then load_strings; fi
}

manage_input_separately () {
	[ ${#} -lt 1 ] && help
	[ ${#} -gt 1 ] && multiple_files=true

    # update messages with presently available vars
    load_strings

	type run_${action} > /dev/null || \
		{ "${kdialog_bin}" --title "${msg_common_software_not_found}" --icon configure --error "${msg_common_action_not_found_text}" && exit 2; }

	[ "${ask_overwrite}" = true ] && overwrite_prompt

	quantity=$#
	dbus_ref=$(kdialog --icon configure --title "${!msg_title}" --progressbar "${msg_common_start}" $quantity)
	processed=0

	for input in "$@"; do
		## Check if window has been closed w. cancel / alt + f4...
		if [ "$?" = 0 ]; then
			dir=$(dirname -- "${input}")
			name="${input##*/}"
			base="${name%.*}"
			ext="${name##*.}"

			processed=$(($processed + 1))
			load_strings
			[ ! -f "${input}" ] && "${kdialog_bin}" --title --icon configure "${!msg_title}" --error "${msg_common_file_not_found}" && break
			qdbus $dbus_ref setLabelText "${msg_common_progress}"

			msg_finish_title=msg_${action}_finish_title
			run_${action} && \
				"${kdialog_bin}" --title "${!msg_finish_title}" --passivepopup "${msg_common_finish_ok}" 5 || \
				{ qdbus $dbus_ref close; "${kdialog_bin}" --icon configure --title "${!msg_finish_title}" --detailederror "${msg_common_finish_error}" "${msg}"; exit 2; }

			qdbus $dbus_ref org.freedesktop.DBus.Properties.Set org.kde.kdialog.ProgressDialog value $processed
		else
			"${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2;
		fi
	done

	qdbus $dbus_ref close
}

manage_input_at_once () {
	[ ${#} -lt 1 ] && help

	dir=$(dirname -- "${1}")
	name="${1##*/}"
	load_strings

	msg_finish_title=msg_${action}_finish_title
	run_${action} "${@}" && \
		"${kdialog_bin}" --title "${!msg_finish_title}" --passivepopup "${msg_common_finish_ok}" 5 || \
		{ qdbus $dbus_ref close; "${kdialog_bin}" --icon configure --title "${!msg_finish_title}" --detailederror "${msg_common_finish_error}" "${msg}"; exit 2; }

}











###################################################################

#### Functions Setup #################

###################################################################

set_reencode_dnxhd () {

	value="${1}"
	vcodec="${value}"
	shift

	############### Default values depending of the protocol

	def_profile="DNxHR(HQ)"
	profile_list=("DNxHR(LB) DNxHR(SQ) DNxHR(HQ) DNxHR(HQX) DNxHR(444)")

	############### Ask for tweaking depending of the protocol

	load_strings

	profile=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_dnxhd_profile_encode_input_text}" $profile_list) || \
		{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
	if [ "${profile}" = "" ]; then profile="${def_profile}"
	fi

	if [ "${profile}" = "DNxHR(LB)" ]; then
		vprofile="dnxhr_lb"; vpixfmt="yuv422p"
	elif [ "${profile}" = "DNxHR(SQ)" ]; then
		vprofile="dnxhr_sq"; vpixfmt="yuv422p"
	elif [ "${profile}" = "DNxHR(HQ)" ]; then
		vprofile="dnxhr_hq"; vpixfmt="yuv422p"
	elif [ "${profile}" = "DNxHR(HQX)" ]; then
		vprofile="dnxhr_hqx"; vpixfmt="yuv422p10le"
	elif [ "${profile}" = "DNxHR(444)" ]; then
		vprofile="dnxhr_444"; vpixfmt="yuv422p10le"
	fi

	ask_overwrite=true

	manage_input_separately "${@}"
}


set_reencode_prores () {

	value="${1}"
	vcodec="${value}"
	shift

	############### Default values depending of the protocol

	def_profile=Auto
	profile_list=("Auto 422(Proxy) 422(LT) 422(Standard) 422(HQ) 4444 4444(XQ)")

	############### Ask for tweaking depending of the protocol

	load_strings

	profile=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_prores_profile_encode_input_text}" $profile_list) || \
		{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
	if [ "${profile}" = "" ]; then profile="${def_profile}"
	fi

	if [ "${profile}" = "422(Proxy)" ]; then
		vprofile="0"
	elif [ "${profile}" = "422(LT)" ]; then
		vprofile="1"
	elif [ "${profile}" = "422(Standard)" ]; then
		vprofile="2"
	elif [ "${profile}" = "422(HQ)" ]; then
		vprofile="3"
	elif [ "${profile}" = "4444" ]; then
		vprofile="4"
	elif [ "${profile}" = "4444(XQ)" ]; then
		vprofile="5"
	fi

	if [ "${profile}" != "Auto" ]; then
		opt_profile=" -profile:v $vprofile"
	fi

	ask_overwrite=true

	manage_input_separately "${@}"
}


set_reencode_h264 () {

	value="${1}"
	vcodec="${value}"
	shift


	############### Detect compatible GPU and choose which encode protocol is used. Important values are decided fron this function

	detect_gpu_h264_hevc
	load_strings

	if [ "${gpu_list}" != "CPU" ]; then
		encoder=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_gpu_encode_input_text}" $gpu_list) || \
			{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
		if [ "${encoder}" = "" ]; then encoder="${def_encoder}"
		fi

		if [ "${encoder}" = "Intel" ]; then
			vcodec="h264_qsv"
		elif [ "${encoder}" = "Nvidia" ]; then
			vcodec="h264_nvenc"
		elif [ "${encoder}" = "CPU" ]; then
			vcodec="libx264"
		fi
	fi

	############### Default values depending of the protocol

	if [ "${vcodec}" = "h264_qsv" ]; then
		def_quality=medium
		quality_list=("veryfast faster fast medium slow slower veryslow")
	elif [ "${vcodec}" = "h264_nvenc" ]; then
		def_quality=p4
		quality_list=("p1 p2 p3 p4 p5 p6 p7")
	elif [ "${vcodec}" = "libx264" ]; then
		def_bitrate=23; def_quality=medium;
		quality_list=("ultrafast superfast veryfast faster fast medium slow slower veryslow")
	fi

	############### Ask for tweaking depending of the protocol

	valid_value="false"

	min_bitrate=0; max_bitrate=51;
	load_strings

	if [ "${vcodec}" = "libx264" ]; then

		while [ "${valid_value}" = "false" ]; do
			vbitrate=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --inputbox "${msg_bitrate_encode_input_text}" $def_bitrate) || \
				{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }

			valid_value="true"

			if [[ ! $vbitrate =~ ^[0-9]+$ ]]; then
				"${kdialog_bin}" --title --icon configure "${!msg_title}" --error "${msg_common_invalid_value}"
				valid_value="false"
			fi
		done

	opt_bitrate=" -crf $vbitrate"
	fi

	vquality=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_quality_encode_input_text}" $quality_list) || \
		{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
	if [ "${vquality}" = "" ]; then vquality="${def_quality}"
	fi

	ask_overwrite=true

	manage_input_separately "${@}"
}


set_reencode_hevc () {

	shift
	value="${1}"
	vcodec="${value}"

	############### Detect compatible GPU and choose which encode protocol is used. Important values are decided fron this function

	detect_gpu_h264_hevc
	load_strings

	if [ "${gpu_list}" != "CPU" ]; then
		encoder=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_gpu_encode_input_text}" $gpu_list) || \
			{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
		if [ "${encoder}" = "" ]; then encoder="${def_encoder}"
		fi

		if [ "${encoder}" = "Intel" ]; then
			vcodec="hevc_qsv"
		elif [ "${encoder}" = "Nvidia" ]; then
			vcodec="hevc_nvenc"
		elif [ "${encoder}" = "CPU" ]; then
			vcodec="libx265"
		fi
	fi

	############### Default values depending of the protocol

	if [ "${vcodec}" = "hevc_qsv" ]; then
		def_quality=medium
		quality_list=("veryfast faster fast medium slow slower veryslow")
	elif [ "${vcodec}" = "hevc_nvenc" ]; then
		def_quality=p4
		quality_list=("p1 p2 p3 p4 p5 p6 p7")
	elif [ "${vcodec}" = "libx265" ]; then
		def_bitrate=28; def_quality=medium;
		quality_list=("ultrafast superfast veryfast faster fast medium slow slower veryslow")
	fi

	############### Ask for tweaking depending of the protocol

	valid_value="false"

	min_bitrate=0; max_bitrate=51;
	load_strings

	if [ "${vcodec}" = "libx265" ]; then

		while [ "${valid_value}" = "false" ]; do
			bitrate=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --inputbox "${msg_bitrate_encode_input_text}" $def_bitrate) || \
				{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }

			valid_value="true"

			if [[ ! $bitrate =~ ^[0-9]+$ ]] || [ $bitrate -lt $min_bitrate ] || [ $bitrate -gt $max_bitrate ]; then
				"${kdialog_bin}" --title --icon configure "${!msg_title}" --error "${msg_common_invalid_value}"
				valid_value="false"
			fi
		done

	opt_bitrate=" -crf $bitrate"
	fi

	vquality=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_quality_encode_input_text}" $quality_list) || \
		{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
	if [ "${vquality}" = "" ]; then vquality="${def_quality}"
	fi

	ask_overwrite=true

	manage_input_separately "${@}"
}


set_reencode_vp9 () {

	shift
	value="${1}"
	vcodec="${value}"


	############### Detect compatible GPU and choose which encode protocol is used. Important values are decided fron this function

	detect_gpu_vp9
	load_strings

	if [ "${gpu_list}" != "CPU" ]; then
		encoder=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_gpu_encode_input_text}" $gpu_list) || \
			{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
		if [ "${encoder}" = "" ]; then encoder="${def_encoder}"
		fi

		if [ "${encoder}" = "Intel" ]; then
			vcodec="vp9_qsv"
		elif [ "${encoder}" = "CPU" ]; then
			vcodec="libvpx-vp9"
		fi
	fi

	############### Default values depending of the protocol

	if [ "${vcodec}" = "vp9_qsv" ]; then
		def_quality=medium; multithread=0;
		quality_list=("veryfast faster fast medium slow slower veryslow")
	elif [ "${vcodec}" = "libvpx-vp9" ]; then
		def_bitrate=31; def_quality=good; multithread=0;
		quality_list=("best good realtime")
	fi

	############### Ask for tweaking depending of the protocol

	valid_value="false"

	min_bitrate=0; max_bitrate=63;
	load_strings

	if [ "${vcodec}" = "libvpx-vp9" ]; then
		while [ "${valid_value}" = "false" ]; do
			bitrate=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --inputbox "${msg_bitrate_encode_input_text}" $def_bitrate) || \
				{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
				if [ "${bitrate}" = "" ]; then bitrate="${def_bitrate}"
				fi

			valid_value="true"

			if [[ ! $bitrate =~ ^[0-9]+$ ]] || [ $bitrate -lt $min_bitrate ] || [ $bitrate -gt $max_bitrate ]; then
				"${kdialog_bin}" --title --icon configure "${!msg_title}" --error "${msg_common_invalid_value}"
				valid_value="false"
			fi
		done

	opt_bitrate=" -crf $bitrate"
	fi

	vquality=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_quality_encode_input_text}" $quality_list) || \
		{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
	if [ "${vquality}" = "" ]; then vquality="${def_quality}"
	fi

	if [ "${vcodec}" = "libvpx-vp9" ]; then
		"${kdialog_bin}" --icon configure --title "${!msg_title}" --yesno "${msg_multithread_input_text}" && multithread=1 || \
			{ [ $? -eq 1 ] && multithread=0 || \
					{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
			}
	fi

	ask_overwrite=true

	manage_input_separately "${@}"
}

set_reencode_audio () {

	value="${1}"
	acodec="${value}"
	shift

	if [ "${acodec}" = "pcm" ]; then
		def_profile="${list_pcm_s16be}"

		load_strings

		profile=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_pcm_profile_encode_input_text}" "${list_pcm_s16be}" "${list_pcm_s24be}" "${list_pcm_f32be}") || \
		{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
		if [ "${profile}" = "" ]; then profile="${def_profile}"
		fi

		if [ "${profile}" = "${list_pcm_s16be}" ]; then
			acodec="pcm_s16be"
		elif [ "${profile}" = "${list_pcm_s24be}" ]; then
			acodec="pcm_s24be"
		elif [ "${profile}" = "${list_pcm_f32be}" ]; then
			acodec="pcm_f32be"
		fi
	fi

	ask_overwrite=true

	manage_input_separately "${@}"
}

set_resize () {

	value="${1}"
	def_profile="${list_resize_fill}"

	shift

	load_strings

	if [ ! "${value}" = "OG_W/2:OG_H/2" ] && [ ! "${value}" = "OG_W/1.333:OG_H/1.333" ] && [ ! "${value}" = "OG_W/4:OG_H/4" ]; then
		profile=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_resize_profile_input_text}" "${list_resize_stretch}" "${list_resize_fill}" "${list_resize_bars}") || \
		{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
		if [ "${profile}" = "" ]; then profile="${def_profile}"
		fi

		# Applied at run for reasons
	fi

	ask_overwrite=true

	manage_input_separately "${@}"
}


set_rewrap () {
	value="${1}"
	shift

	if [ "${value}" = "custom" ]; then
		format=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --inputbox "${msg_rewrap_format_input_text}") || \
			{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
	else
		format="${value}"
	fi

	for arg in "$@"; do
		arg_ext="${arg##*.}"
		[ "${arg_ext}" = "${format}" ] && ask_overwrite=true && break
	done

	manage_input_separately "${@}"
}

set_interpolate () {
	value="${1}"
	shift
	############### Default values depending of the protocol
	def_multi=2
	def_model=RIFE
	multiplicator_list=("2 4 6 8")
	model_list=("$rife_list $dain_list Minterpolate")

	detect_gpu_interpolate

	load_strings

	if [ "${gpu_list}" != "CPU" ] && [ ! -z "${rife_bin}" ]; then
		model=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_gpu_interpolate_input_text}" $model_list) || \
			{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
		if [ "${model}" = "" ]; then model="${def_model}"
		fi

		if [ "${model}" = "RIFE" ]; then
			value="${rife_bin}"
		elif [ "${model}" = "DAIN" ]; then
			value="${dain_bin}"
		elif [ "${model}" = "Minterpolate" ]; then
			value="minterpolate"
		fi
	fi

	multiplicator=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_interpolate_multiplicator_input_text}" ${multiplicator_list} ) || \
		{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
	if [ "${multiplicator}" = "" ]; then multiplicator="${def_multi}"
	fi

	ask_overwrite=true

	manage_input_separately "${@}"
}

set_restore () {
	value="${1}"
	shift
	############### Default values depending of the protocol

	def_subaction=${list_restore_denoise}
	subaction=${list_restore_denoise}
	upscale_list=("2 3 4")
	denoise_list=("2 4 6 8")
	valid_value="false"

	detect_gpu_restore

	load_strings

	if [ "${gpu_list}" != "CPU" ] && [ ! -z "${realesrgan_bin}" ]; then
		subaction=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_subaction_input_text}" "${list_restore_denoise}" "${list_restore_upscale}" "${list_restore_all}" ) || \
			{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
		if [ "${subaction}" = "" ]; then subaction="${def_subaction}"
		fi
	fi

	############### Denoise
	if [ "${subaction}" = "${list_restore_denoise}" ]; then

		if [ "${gpu_list}" != "CPU" ]; then
			def_model=${srmd_list_min}

			load_strings

			model=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_restore_gpu_input_text}" "${srmd_list}" "${list_nlmeans}" "${list_atadenoiser}") || \
				{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
			if [ "${model}" = "" ]; then model="${def_model}"
			fi

			if [ "${model}" = "${srmd_list}" ]; then
				value="${srmd_bin}"; title_model="SRMD"
				min_denoise=0; max_denoise=10; def_denoise=3
			elif [ "${model}" = "${list_nlmeans}" ]; then
				value="nlmeans"; title_model="Nlmeans"
				min_denoise=0; max_denoise=30; def_denoise=1
			elif [ "${model}" = "${list_atadenoiser}" ]; then
				value="atadenoiser"; title_model="Atadenoiser"
				min_denoise=0; max_denoise=5; def_denoise=0.04
			fi

			load_strings

			while [ "${valid_value}" = "false" ]; do
				denoise=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --inputbox "${msg_restore_denoise_input_text}" $def_denoise ) || \
					{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
					if [ "${denoise}" = "" ]; then denoise="${def_denoise}"
					fi

				valid_value="true"

				if [[ ! $denoise =~ ^[0.00-9.99]+$ ]] || [ $denoise -lt $min_denoise ] || [ $denoise -gt $max_denoise ]; then
					"${kdialog_bin}" --title --icon configure "${!msg_title}" --error "${msg_common_invalid_value}"
					valid_value="false"
				fi
			done

		else
			def_model=${list_nlmeans}

			load_strings

			model=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_restore_gpu_input_text}" "${list_nlmeans}" "${list_atadenoiser}") || \
				{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
			if [ "${model}" = "" ]; then model="${def_model}"
			fi
		fi

		if [ "${model}" = "${realesrgan_list}" ]; then
			value="${realesrgan_bin}"; title_model="Real-ESRGAN"
		elif [ "${model}" = "${list_nlmeans}" ]; then
			value="nlmeans"; title_model="Nlmeans"
		elif [ "${model}" = "${list_atadenoiser}" ]; then
			value="atadenoiser"; title_model="Atadenoiser"
		fi

	############### Upscale
	elif [ "${subaction}" = "${list_restore_upscale}" ]; then

		def_multi=2

		load_strings

		model=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_restore_gpu_input_text}" "${srmd_list}" "${realsr_list}" "${realesrgan_list}") || \
				{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
			if [ "${model}" = "" ]; then model="${def_model}"
			fi

		if [ "${model}" == *"${srmd_list_min}"* ]; then
			value="${srmd_bin}"; title_model="SRMD"
		elif [ "${model}" == *"${realsr_list_min}"* ]; then
			value="${realsr_bin}"; title_model="RealSR"
		elif [ "${model}" == *"${realesrgan_list_min}"* ]; then
			value="${realesrgan_bin}"; title_model="Real-ESRGAN"
		fi

		load_strings

		multiplicator=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_restore_upscale_input_text}" ${upscale_list} ) || \
		{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
		if [ "${upscale}" = "" ]; then upscale="${def_multi}"
		fi

		opt_restore=" -n 2 -s $upscale"

	############### Upscale and Denoize
	elif [ "${subaction}" = "${list_restore_all}" ]; then

		def_multi=2
		def_denoise=2

		load_strings

		model=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_restore_gpu_input_text}" "${realsr_list}" "${realesrgan_list}") || \
			{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
		if [ "${model}" = "" ]; then model="${def_model}"
		fi

		if [ "${model}" == *"${realsr_list_min}"* ]; then
			value="${realsr_bin}"; title_model="RealSR"
		elif [ "${model}" == *"${list_nlmeans_min}"* ]; then
			value="${realesrgan_bin}"; title_model="Real-ESRGAN"
		fi

		load_strings

		multiplicator=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_restore_denoise_input_text}" ${denoise_list} ) || \
			{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
		if [ "${denoise}" = "" ]; then denoise="${def_denoise}"
		fi

		load_strings

		upscale=$("${kdialog_bin}" --icon configure --title "${!msg_title}" --combobox "${msg_restore_upscale_input_text}" ${upscale_list} ) || \
			{ "${kdialog_bin}" --title "${!msg_title}" --passivepopup "${msg_common_abort}" 5 && exit 2; }
		if [ "${upscale}" = "" ]; then upscale="${def_multi}"
		fi

		opt_restore=" -n $denoise -s $upscale"

	fi

	ask_overwrite=true

	manage_input_separately "${@}"
}

